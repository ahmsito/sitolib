{
  "name": "sitolib",
  "version": "1.1.2",
  "description": "A CLI UI library with ASCII table support and colorful logging",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./asciitable": {
      "types": "./dist/cliui/asciitable/index.d.ts",
      "import": "./dist/cliui/asciitable/index.js"
    },
    "./core": {
      "types": "./dist/cliui/core/index.d.ts",
      "import": "./dist/cliui/core/index.js"
    },
    "./formatting": {
      "types": "./dist/cliui/formatting/index.d.ts",
      "import": "./dist/cliui/formatting/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run minify",
    "minify": "node scripts/minify.js",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node test.js",
    "test:core": "npm run build && node test-core.js",
    "test:table": "npm run build && node test.js",
    "test:formatting": "npm run build && node test-formatting.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "terser": "^5.46.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "cli",
    "ui",
    "ascii",
    "table",
    "logging",
    "colors",
    "rainbow",
    "terminal",
    "console"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmsito/sitolib"
  },
  "bugs": {
    "url": "https://github.com/ahmsito/sitolib/issues"
  },
  "homepage": "https://github.com/ahmsito/sitolib#readme",
  "author": "ahmesito",
  "license": "MIT",
  "engines": {
    "node": ">=14.0.0"
  }
}
